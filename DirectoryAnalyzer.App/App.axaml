<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DirectoryAnalyzer.App.ViewModels"
             xmlns:conv="clr-namespace:DirectoryAnalyzer.App.Converters"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="DirectoryAnalyzer.App.App">
  <Application.Styles>
    <fluent:FluentTheme />
  </Application.Styles>

  <Application.DataTemplates>
  </Application.DataTemplates>

  <Application.Resources>
    <conv:BoolToIconConverter x:Key="BoolToIconConverter" />
    <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
  </Application.Resources>
</Application>

